# Vite 环境变量
VITE_API_URL=http://localhost:5000

# Flask 环境
FLASK_ENV=development
FLASK_DEBUG=1

# ==================== 百川 M3 API 配置 ====================
# 获取地址: https://www.baichuanai.cn/
BAICHUAN_API_URL=https://api.baichuan-ai.com/v1/chat/completions
BAICHUAN_API_KEY=your_baichuan_api_key_here
BAICHUAN_MODEL=Baichuan-M3

# ==================== Agent Loop V2 (Canary) ====================
# Enable loop-oriented orchestrator: 0/1
AGENT_LOOP_V2_ENABLED=0
# Canary ratio in [0,1]. 0=disabled, 1=all runs
AGENT_LOOP_V2_CANARY_RATIO=0.0
# guarded_hybrid | rule_only | llm_first
AGENT_LOOP_V2_PLANNER_MODE=guarded_hybrid
# Pause when high-risk conflict is detected
AGENT_HUMAN_REVIEW_PAUSE=0
# Loop safety limits
AGENT_LOOP_MAX_STEPS=24
AGENT_LOOP_MAX_DURATION_MS=900000

# ==================== Startup Warmup (Hybrid) ====================
# 1=boot fast and warm models in background
MODEL_WARMUP_ASYNC=1
# Wait timeout (ms) when request needs models before warmup completes
MODEL_WARMUP_WAIT_TIMEOUT_MS=12000
# Wait timeout (ms) for strict CTP generation gate (cbf+cbv+tmax all required)
MODEL_WARMUP_CTP_TIMEOUT_MS=120000
