# 百川 M3 API 配置
# 获取方式: https://www.baichuan-ai.com
BAICHUAN_API_KEY=sk-your-api-key-here
BAICHUAN_SECRET_KEY=
BAICHUAN_API_URL=https://api.baichuan-ai.com/v1

# 可选：知识库配置（如果使用知识库检索功能）
BAICHUAN_KNOWLEDGE_BASE_ID=default

# Supabase 配置
# 获取方式: https://supabase.com
SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxx
SUPABASE_ANON_KEY=your-anon-key-here

# 后端 API 配置（如果需要）
BACKEND_URL=http://localhost:5000

# 应用配置
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
