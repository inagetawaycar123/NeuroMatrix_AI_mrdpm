    "README.md"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:lib": "rollup -c rollup.config.mjs && npm run build:types",
    "build:types": "tsc --project tsconfig.lib.json",
    "start": "next start",
    "lint": "next lint",
    "prepublishOnly": "npm run build:lib"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-scroll-area": "^1.0.5",
    "@supabase/supabase-js": "^2.93.2",
    "ai": "^2.2.0",
    "autoprefixer": "^10.0.1",
    "lucide-react": "^0.294.0",
    "next": "14.0.0",
    "postcss": "^8.0.9",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "tailwindcss": "^3.3.0"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^25.0.0",
    "@rollup/plugin-node-resolve": "^15.0.0",
    "@rollup/plugin-typescript": "^11.0.0",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.4.0",
    "eslint": "^8",
    "eslint-config-next": "14.0.0",
    "postcss": "^8.4.0",
    "rollup": "^4.0.0",
    "rollup-plugin-peer-deps-external": "^2.2.4",
    "rollup-plugin-postcss": "^4.0.2",
    "tailwindcss": "^3.3.0",
    "typescript": "^5"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
