{
    "name": "mCTA2CTP",
    "gpu_ids": [0],
    "seed" : -1,
    "finetune_norm": false,

    "path": {
        "base_dir": "J:\\my_palette\\experiments",
        "code": "code",
        "tb_logger": "tb_logger",
        "results": "results",
        "checkpoint": "checkpoint",
        "resume_state":"G:\\NeuroMatrix AI\\weights_0\\cbv\\140"
    },

    "datasets": {
        "train": {
            "which_dataset": {
                "name": ["data.dataset", "NumpyDataset_mask"],
                "args":{
                    "data_root": "G:\\new_palette_cbf\\train",
                    "data_flist": "G:\\new_palette_cbf\\train_cbf_list.txt",
                    "data_len": -1
                }
            },
            "dataloader":{
                "validation_split": 10,
                "args":{
                    "batch_size": 4,
                    "num_workers": 4,
                    "shuffle": true,
                    "pin_memory": true,
                    "drop_last": true
                },
                "val_args":{
                    "batch_size": 1,
                    "num_workers": 4,
                    "shuffle": false,
                    "pin_memory": true,
                    "drop_last": false
                }
            }
        },
        "test": {
            "which_dataset": {
                "name": "NumpyDataset_mask",
                "args":{
                    "data_root": "G:\\medical_imaging_app\\static",
                    "data_flist": "G:\\new_palette_cbf\\test_cbf_list.txt"
                }
            },
            "dataloader":{
                "args":{
                    "batch_size": 1,
                    "num_workers": 4,
                    "pin_memory": true
                }
            }
        }
    },

    "model": {
        "which_model": {
            "name": ["models.model", "Palette"],
            "args": {
                "sample_num": 4,
                "task": "my_mission_mask",
                "ema_scheduler": {
                    "ema_start": 1,
                    "ema_iter": 1,
                    "ema_decay": 0.9999
                },
                "optimizers": [
                    { "lr": 5e-5, "weight_decay": 0}
                ]
            }
        },
        "which_networks": [
            {
                "name": ["models.network", "Network"],
                "args": {
                    "init_type": "kaiming",
                    "module_name": "guided_diffusion",
                    "unet": {
                        "in_channel": 4,
                        "out_channel": 1,
                        "inner_channel": 64,
                        "channel_mults": [
                            1,
                            2,
                            4,
                            8
                        ],
                        "attn_res": [
                            16
                        ],
                        "num_head_channels": 32,
                        "res_blocks": 2,
                        "dropout": 0.2,
                        "image_size": 256
                    },
                    "beta_schedule": {
                        "train": {
                            "schedule": "linear",
                            "n_timestep": 1000,
                            "linear_start": 1e-6,
                            "linear_end": 0.01
                        },
                        "test": {
                            "schedule": "linear",
                            "n_timestep": 1000,
                            "linear_start": 1e-6,
                            "linear_end": 0.01
                        }
                    }
                }
            }
        ],
        "which_losses": [
            "mse_loss"
        ],
        "which_metrics": [
            "mae"
        ]
    },

    "train": {
        "n_epoch": 200,
        "n_iter": 1e8,
        "val_epoch": 10,
        "save_checkpoint_epoch": 10,
        "log_iter": 2000,
        "tensorboard" : true
    },

    "debug": {
        "val_epoch": 1,
        "save_checkpoint_epoch": 1,
        "log_iter": 10,
        "debug_split": 50
    }
}
